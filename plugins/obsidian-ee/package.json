{
  "name": "obsidian-ee",
  "version": "0.1.0",
  "description": "E2E encrypted collaborative editing for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "test": "jest",
    "test:watch": "jest --watch",
